{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "trips": {
      "$tripId": {
        ".read": "auth != null && data.child('members').child(auth.uid).exists()",
        ".write": "auth != null && (data.child('createdByUid').val() === auth.uid || (!data.exists() && newData.child('createdByUid').val() === auth.uid))",

        "members": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "updatedAt": {
          ".write": "auth != null && (data.parent().child('members').child(auth.uid).exists() || newData.parent().child('members').child(auth.uid).exists())"
        },
        "items": {
          "$itemId": {
            "responses": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid"
              }
            }
          }
        }
      }
    },

    "tripInviteCodes": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || newData.val() === data.val() || newData.val() === null)"
      }
    },

    "userTrips": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null"
      }
    }
  }
}
