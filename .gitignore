# Claude Code session/job metadata
.claude/

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/
/linux

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Flutter desktop ephemeral
**/linux/flutter/ephemeral/
**/windows/flutter/ephemeral/
**/macos/Flutter/ephemeral/

# Firebase config — contains project API keys, generated per developer
lib/firebase_options.dart
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
.firebase/
firebase-debug.log

# Local env
.env
.env.*

# Generated launcher icons intermediate
assets/icons/.generated/

# CI/CD secret material — never commit these, whatever directory they end up in.
# (Signing keystore + key.properties are also covered under android/.gitignore,
# repeated here in case anything is ever generated/copied to repo root.)
*.jks
*.keystore
key.properties
*-b64.txt
*.b64
*firebase-adminsdk*.json
*service-account*.json
serviceAccountKey.json
